# ========== AURA Configuration ==========
# See BEST_PRACTICES.md for detailed documentation
# See SECURITY.md for security requirements

# ===== REQUIRED (Production) =====
# Backend Campus Controller API endpoint - MUST be set, no fallback
CAMPUS_CONTROLLER_URL=https://campus.example.com/api

# Allowed frontend origins (comma-separated)
# Example: https://aura.example.com,https://aura-backup.example.com
# CRITICAL: Set this to specific origins in production (not wildcards)
CORS_ORIGINS=http://localhost:3000

# ===== RECOMMENDED (Production) =====
# Runtime environment
NODE_ENV=development

# Server port
PORT=3000

# Sentry DSN for error tracking and performance monitoring (optional)
# Get your DSN from https://sentry.io/
# Example: https://xxxx@yyyy.ingest.sentry.io/nnnn
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===== Rate Limiting (Optional, Production) =====
# Rate limit time window in milliseconds
# Default: 900000 (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per rate limit window
# Default: 100 requests
RATE_LIMIT_MAX_REQUESTS=100

# ===== TLS/SSL (Production) =====
# Only disable in development with self-signed certificates
# NEVER set to '0' in production
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Path to custom CA certificate (production)
# TLS_CA_CERT=/etc/ssl/certs/ca.crt

# ===== Logging (Optional) =====
# Server log level: 'debug' | 'info' | 'warn' | 'error'
# Default: 'info'
# LOG_LEVEL=info

# ===== LLM Provider Keys (any subset — picker shows configured providers) =====
# server.js reads process.env directly; export these in the shell you launch
# `node server.js` from, or set them in your process manager (Railway, pm2, ...).
# Local-dev shortcut:
#   export OLLAMA_ENABLED=true OLLAMA_API_BASE=http://192.168.100.177:11434/v1 && npm run start

# ANTHROPIC_API_KEY=          # Claude Sonnet 4.6 / Opus 4.7 / Haiku 4.5
# OPENAI_API_KEY=             # GPT-4o family
# GROQ_API_KEY=               # gsk_… → Groq Cloud (Llama 3.x, Mixtral, GPT-OSS)
# GROK_API_KEY=               # xai-… → xAI Grok 3 / 3 Mini
# GEMINI_API_KEY=             # Google Gemini 2.0 Flash / 1.5 Pro (generous free tier)
# MISTRAL_API_KEY=            # Mistral Small / 7B / Large
# CEREBRAS_API_KEY=           # Cerebras-hosted Llama 3.3 70B / 3.1 8B (ultra-fast)
# DEEPSEEK_API_KEY=           # DeepSeek V3 / R1 reasoner

# Local Ollama on the redq box (no API key needed)
# OLLAMA_ENABLED=true
# OLLAMA_API_BASE=http://192.168.100.177:11434/v1

# ===== DEPRECATED - DO NOT USE =====
# These variables should NEVER be used. They are exposed to the browser.
# VITE_CAMPUS_CONTROLLER_USER=  # NEVER use - exposed in client JS
# VITE_CAMPUS_CONTROLLER_PASSWORD=  # NEVER use - exposed in client JS
