# ========== AURA Configuration ==========
# See BEST_PRACTICES.md for detailed documentation
# See SECURITY.md for security requirements

# ===== REQUIRED (Production) =====
# Backend Campus Controller API endpoint - MUST be set, no fallback
CAMPUS_CONTROLLER_URL=https://campus.example.com/api

# Allowed frontend origins (comma-separated)
# Example: https://aura.example.com,https://aura-backup.example.com
# CRITICAL: Set this to specific origins in production (not wildcards)
CORS_ORIGINS=http://localhost:3000

# ===== RECOMMENDED (Production) =====
# Runtime environment
NODE_ENV=development

# Server port
PORT=3000

# ===== Rate Limiting (Optional, Production) =====
# Rate limit time window in milliseconds
# Default: 900000 (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per rate limit window
# Default: 100 requests
RATE_LIMIT_MAX_REQUESTS=100

# ===== TLS/SSL (Production) =====
# Only disable in development with self-signed certificates
# NEVER set to '0' in production
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Path to custom CA certificate (production)
# TLS_CA_CERT=/etc/ssl/certs/ca.crt

# ===== Logging (Optional) =====
# Server log level: 'debug' | 'info' | 'warn' | 'error'
# Default: 'info'
# LOG_LEVEL=info

# ===== DEPRECATED - DO NOT USE =====
# These variables should NEVER be used. They are exposed to the browser.
# VITE_CAMPUS_CONTROLLER_USER=  # NEVER use - exposed in client JS
# VITE_CAMPUS_CONTROLLER_PASSWORD=  # NEVER use - exposed in client JS
