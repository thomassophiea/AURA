# Campus Controller Configuration
CAMPUS_CONTROLLER_URL=https://your-controller.example.com

# CORS: comma-separated list of allowed frontend origins in production.
# Example: https://aura.example.com,https://aura-staging.example.com
# In development, localhost is always permitted automatically.
ALLOWED_ORIGINS=https://your-app.up.railway.app

# Development: Direct connection to Campus Controller (optional)
# Only used in development mode when not using the proxy
VITE_DEV_CAMPUS_CONTROLLER_URL=https://your-controller.example.com:443

# Port Configuration (Railway will set this automatically)
PORT=3000

# Supabase Configuration for Historical Data (required for Network Rewind / metrics features)
# These are the PUBLIC project URL and anon key — safe to expose to the browser.
# Find these in your Supabase project dashboard under Settings > API.
# NEVER put the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
